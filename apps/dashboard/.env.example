# Valores reales: en el gestor de contraseñas compartido y en Vercel. JAMÁS en git.
# La clave anon es la pública (RLS manda).
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU-CLAVE-ANON

# D1 — solo server-side (sin NEXT_PUBLIC_): el browser jamás los ve.
# service_role: lee runs (RLS sin policies). Solo se usa en el BFF.
SUPABASE_SERVICE_ROLE=TU-SERVICE-ROLE
# Lectura read-only de Voces/Proyectos/Ajustes mientras la config viva en Airtable (muere en D5).
AIRTABLE_PAT=TU-PAT-DE-AIRTABLE
AIRTABLE_BASE_ID=TU-BASE-ID
# ▶ Correr ahora: URL de Producción del webhook del motor + el header de la
# credencial `Webhook Motor Header` de n8n. Deben coincidir EXACTO (si no: 403).
MOTOR_WEBHOOK_URL=https://TU-N8N/webhook/TU-PATH
MOTOR_WEBHOOK_HEADER_NOMBRE=TU-NOMBRE-DE-HEADER
MOTOR_WEBHOOK_HEADER_VALOR=TU-VALOR-DE-HEADER

# D4 — la fachada GET /api/engine/run-plan (ADR-028, contrato core/contracts/run-plan.md).
# El header que n8n manda al preguntar qué correr. Otro par, NO reusar el del webhook.
RUN_PLAN_HEADER_NOMBRE=TU-NOMBRE-DE-HEADER-RUN-PLAN
RUN_PLAN_HEADER_VALOR=TU-VALOR-DE-HEADER-RUN-PLAN
