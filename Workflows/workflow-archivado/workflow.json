    {
      "id": "m1-prep-borrado-desc",
      "name": "Preparar borrado Descartes",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3160,
        650
      ],
      "parameters": {
        "jsCode": "\n// Limpia los Descartes del gate al cerrar la semana (ADR-021): auditados o no, no se acumulan\n// (la próxima corrida trae su propia banda). El conteo de 'era bueno' ya quedó en Métricas.\nlet ids = [];\ntry { ids = $('Leer Descartes del gate').all().flatMap(it => (it.json && it.json.records) || []).map(r => r.id).filter(Boolean); } catch (e) {}\nconst base = $('Config').first().json.airtable_base_id;\nconst out = [];\nfor (let i = 0; i < ids.length; i += 10) {\n  const qs = ids.slice(i, i + 10).map(id => 'records[]=' + encodeURIComponent(id)).join('&');\n  out.push({ json: { url: 'https://api.airtable.com/v0/' + base + '/' + encodeURIComponent('Descartes del gate') + '?' + qs } });\n}\nreturn out; // [] si no hay nada que borrar: el DELETE no corre (rama lateral, no bloquea Cerrar run)\n"
      }
    },
