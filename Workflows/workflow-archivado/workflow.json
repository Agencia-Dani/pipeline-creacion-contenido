    {
      "parameters": {
        "jsCode": "\nconst ids = $('Armar filas archivado').all().map(i => i.json.record_id);\nconst base = $('Config').first().json.airtable_base_id;\nconst out = [];\nfor (let i = 0; i < ids.length; i += 10) {\n  const qs = ids.slice(i, i + 10).map(id => 'records[]=' + encodeURIComponent(id)).join('&');\n  out.push({ json: { url: 'https://api.airtable.com/v0/' + base + '/Candidatos?' + qs } });\n}\nreturn out;\n"
